# ──────────────────────────────────────────────────────────────
# Provider LLM — "vertexai" (défaut) | "openai"
# ──────────────────────────────────────────────────────────────
LLM_PROVIDER=vertexai
EMBEDDING_PROVIDER=vertexai

# ──────────────────────────────────────────────────────────────
# Modèles
# ──────────────────────────────────────────────────────────────
LLM_MODEL=gemini-3.1-flash-lite
EMBEDDING_MODEL=text-multilingual-embedding-002

# ──────────────────────────────────────────────────────────────
# Vertex AI (prérequis : gcloud auth application-default login)
# ──────────────────────────────────────────────────────────────
VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=global

# ──────────────────────────────────────────────────────────────
# OpenAI — alternative si LLM_PROVIDER=openai
# ──────────────────────────────────────────────────────────────
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-...

# ──────────────────────────────────────────────────────────────
# Base de données PostgreSQL
# ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://bforbank:bforbank@localhost:5432/bforbank

# ──────────────────────────────────────────────────────────────
# Langfuse — Observabilité (optionnel, désactivé si vide)
# UI disponible sur http://localhost:3000 après docker compose up
# Créer un projet sur l'UI pour obtenir les clés.
# ──────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
